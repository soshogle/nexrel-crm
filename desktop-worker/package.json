{
  "name": "nexrel-desktop-worker",
  "version": "1.0.0",
  "private": true,
  "description": "Nexrel AI Desktop Worker for macOS and Windows",
  "main": "src/main.js",
  "author": "Nexrel",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "dist": "electron-builder -mwl",
    "dist:mac": "electron-builder --mac dmg",
    "dist:win": "electron-builder --win nsis",
    "pack": "electron-builder --dir"
  },
  "dependencies": {
    "playwright": "^1.57.0"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.nexrel.desktopworker",
    "productName": "Nexrel Desktop Worker",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "directories": {
      "output": "dist"
    }
  }
}
